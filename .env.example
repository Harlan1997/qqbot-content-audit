# ===== NoneBot2 配置 =====
DRIVER=~fastapi
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO

# ===== OneBot v11 连接 =====
# NapCat 反向 WebSocket 会主动连接此地址，无需额外配置

# ===== Google AI (Gemini) =====
GEMINI_API_KEY=your-gemini-api-key-here

# ===== 审核配置 =====
# 启用审核的群号列表（逗号分隔），留空表示所有群
MOD_GROUP_IDS=
# 审核模式: strict / normal / loose
MOD_POLICY=strict
# 管理员QQ号列表（逗号分隔）
MOD_ADMIN_QQ=
